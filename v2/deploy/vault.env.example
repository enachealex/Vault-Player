# Account secrets for the Vault backend. Copy to deploy/vault.env on the
# server (which is gitignored) and fill in. Never commit the real file.

# Signing key for access tokens. Generate a strong one:
#   openssl rand -base64 48
VAULT_JWT_SECRET=

# Transactional email (Gmail SMTP with an app password, or any provider).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vaultjump.noreply@gmail.com
SMTP_PASS=
SMTP_FROM=vaultjump.noreply@gmail.com
SMTP_FROM_NAME=Vault Movies
