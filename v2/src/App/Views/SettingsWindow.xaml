<Window x:Class="VideoPlayer.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="460" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource BodyFont}">
    <StackPanel Margin="24">
        <TextBlock Text="Settings" FontSize="19" FontWeight="Bold"
                   FontFamily="{StaticResource DisplayFont}"
                   Foreground="{StaticResource TextBrush}" />

        <!-- Audio output -->
        <TextBlock Text="AUDIO OUTPUT" FontSize="10.5" FontWeight="Bold"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,20,0,6" />
        <TextBlock Text="Where film sound plays. Pick your headphones or speakers if audio comes out of the wrong device."
                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,10" />
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="6">
            <StackPanel x:Name="DeviceList" />
        </Border>
        <TextBlock x:Name="AudioHint" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="2,8,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Done" Style="{StaticResource PrimaryButton}" Padding="18,7"
                    Click="Done_Click" IsDefault="True" AutomationProperties.Name="Done" />
        </StackPanel>
    </StackPanel>
</Window>
