<UserControl x:Class="VideoPlayer.App.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VideoPlayer.App.Models">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,18,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource GhostButton}" Click="HomeBtn_Click"
                    AutomationProperties.Name="Home" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Home" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                <TextBlock x:Name="FolderTitle" Text="Your movies" FontSize="20" FontWeight="Bold"
                           FontFamily="{StaticResource DisplayFont}"
                           Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FolderSubtitle" Text="" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Click="ChangeFolderBtn_Click"
                    AutomationProperties.Name="Choose folder">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="FolderBtnText" Text="Choose folder" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search + sort -->
        <Grid x:Name="Toolbar" Grid.Row="1" Margin="24,0,24,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" MaxWidth="420"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" Margin="12,0,8,0"
                               VerticalAlignment="Center" />
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchBox" Width="300" Padding="0,9" FontSize="13.5"
                                 Background="Transparent" Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0" TextChanged="SearchBox_TextChanged"
                                 AutomationProperties.Name="Search movies" />
                        <TextBlock x:Name="SearchHint" Text="Search your movies…" FontSize="13.5"
                                   Foreground="{StaticResource TextMutedBrush}" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Margin="2,0,0,0" />
                    </Grid>
                    <Button x:Name="ClearSearchBtn" Grid.Column="2" Style="{StaticResource GhostButton}"
                            Padding="8,4" Margin="4,4,6,4" Visibility="Collapsed" Click="ClearSearch_Click"
                            AutomationProperties.Name="Clear search">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource GhostButton}" Click="AddShortcutBtn_Click"
                        Padding="12,8" Margin="0,0,14,0"
                        ToolTip="Add a title you own on a streaming service"
                        AutomationProperties.Name="Add streaming shortcut">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Streaming" FontSize="12.5" />
                    </StackPanel>
                </Button>
                <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox x:Name="SortBox" Width="180" SelectionChanged="SortBox_SelectionChanged"
                          AutomationProperties.Name="Sort order" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,10,0">
            <StackPanel>

                <!-- Continue watching -->
                <StackPanel x:Name="ContinuePanel" Visibility="Collapsed" Margin="0,0,0,22">
                    <TextBlock Text="Continue watching" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ContinueList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:MovieItem}">
                                    <Button Style="{StaticResource MovieCard}" Click="MovieCard_Click"
                                            Tag="{Binding}" AutomationProperties.Name="{Binding Name}">
                                        <StackPanel>
                                            <Border Height="120" Background="{StaticResource BgDeepBrush}" CornerRadius="12,12,0,0">
                                                <Grid>
                                                    <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="34"
                                                               Foreground="{StaticResource TextMutedBrush}" Opacity="0.55"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Border CornerRadius="12,12,0,0">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                                        </Border.Background>
                                                    </Border>
                                                    <ProgressBar Value="{Binding ProgressFraction, Mode=OneWay}" Maximum="1"
                                                                 Height="4" VerticalAlignment="Bottom"
                                                                 Background="#66000000" Foreground="{StaticResource AccentBrush}"
                                                                 BorderThickness="0" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Margin="14,10,14,12">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ResumeText}" FontSize="11.5" Margin="0,4,0,0"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                    <TextBlock x:Name="AllHeader" Text="All movies" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Visibility="Collapsed" />
                    <TextBlock x:Name="FilterCount" Text="" FontSize="12" Margin="10,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>

                <Grid>
                    <ItemsControl x:Name="MovieList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MovieItem}">
                                <Button Style="{StaticResource MovieCard}" Click="MovieCard_Click"
                                        Tag="{Binding}" AutomationProperties.Name="{Binding Name}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Remove shortcut" Click="RemoveShortcut_Click"
                                                      Tag="{Binding PlacementTarget.Tag,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel>
                                        <Border Height="120" Background="{StaticResource BgDeepBrush}" CornerRadius="12,12,0,0">
                                            <Grid>
                                                <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="34"
                                                           Foreground="{StaticResource TextMutedBrush}" Opacity="0.55"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Border CornerRadius="12,12,0,0">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>
                                                <!-- Streaming shortcut: launches the service, never plays here.
                                                     Sits above the poster so it stays legible if one is ever set. -->
                                                <Border Background="#CC0E0604" CornerRadius="9" Padding="8,3"
                                                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="7"
                                                        Visibility="{Binding ShortcutBadgeVisibility}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE7B5;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="9" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource AccentWarmBrush}" />
                                                        <TextBlock Text="{Binding Service}" FontSize="10.5" Margin="6,0,0,0"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentWarmBrush}" />
                                                    </StackPanel>
                                                </Border>
                                                <!-- Times-watched badge -->
                                                <Border Background="#CC0E0604" CornerRadius="9" Padding="7,2"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="7"
                                                        Visibility="{Binding WatchBadgeVisibility}"
                                                        ToolTip="{Binding WatchTooltip}">
                                                    <TextBlock Text="{Binding WatchBadgeText}" FontSize="11"
                                                               FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                                </Border>
                                                <ProgressBar Value="{Binding ProgressFraction, Mode=OneWay}" Maximum="1"
                                                             Height="4" VerticalAlignment="Bottom"
                                                             Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                                             BorderThickness="0" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Margin="14,10,14,12">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding MetaText}" FontSize="11.5" Margin="0,4,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty / no-results state -->
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed" Margin="0,60,0,0">
                        <TextBlock x:Name="EmptyGlyph" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="44"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="EmptyTitle" Text="No folder selected" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,16,0,6" />
                        <TextBlock x:Name="EmptyText" Text="Choose the folder where your movies live — only video files will be listed."
                                   FontSize="13" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="360" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
