<Window x:Class="VideoPlayer.App.Views.AccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account"
        Width="420" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource BodyFont}">
    <StackPanel Margin="24">
        <TextBlock x:Name="Heading" Text="Sign in" FontSize="19" FontWeight="Bold"
                   FontFamily="{StaticResource DisplayFont}"
                   Foreground="{StaticResource TextBrush}" />
        <TextBlock x:Name="Subhead"
                   Text="Sign in to sync your library — resume points and watch counts — across your computers. Optional; everything works without it."
                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="0,6,0,18" />

        <!-- Signed-out form -->
        <StackPanel x:Name="FormPanel">
            <StackPanel x:Name="NameRow" Visibility="Collapsed">
                <TextBlock Text="DISPLAY NAME" FontSize="10.5" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,14">
                    <TextBox x:Name="NameBox" Padding="10,9" FontSize="13.5" MaxLength="30"
                             Background="Transparent" Foreground="{StaticResource TextBrush}"
                             BorderThickness="0" AutomationProperties.Name="Display name" />
                </Border>
            </StackPanel>

            <TextBlock Text="EMAIL" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,14">
                <TextBox x:Name="EmailBox" Padding="10,9" FontSize="13.5"
                         Background="Transparent" Foreground="{StaticResource TextBrush}"
                         BorderThickness="0" AutomationProperties.Name="Email" />
            </Border>

            <TextBlock Text="PASSWORD" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                <PasswordBox x:Name="PassBox" Padding="10,9" FontSize="13.5"
                             Background="Transparent" Foreground="{StaticResource TextBrush}"
                             BorderThickness="0" AutomationProperties.Name="Password" />
            </Border>
            <TextBlock x:Name="PassHint" Text="At least 8 characters." FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}" Margin="2,6,0,0" Visibility="Collapsed" />

            <TextBlock x:Name="ErrorText" Text="" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource AccentBrush}" Margin="0,12,0,0" Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="ToggleBtn" Content="Create account" Style="{StaticResource GhostButton}"
                        Padding="12,7" Margin="0,0,10,0" Click="Toggle_Click"
                        AutomationProperties.Name="Switch mode" />
                <Button x:Name="SubmitBtn" Content="Sign in" Style="{StaticResource PrimaryButton}"
                        Padding="18,7" Click="Submit_Click" IsDefault="True"
                        AutomationProperties.Name="Submit" />
            </StackPanel>
        </StackPanel>

        <!-- Signed-in state -->
        <StackPanel x:Name="SignedInPanel" Visibility="Collapsed">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16,12">
                <StackPanel>
                    <TextBlock x:Name="WhoName" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="WhoEmail" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0" />
                    <TextBlock x:Name="SyncStatus" FontSize="12" Foreground="{StaticResource AccentWarmBrush}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Sign out" Style="{StaticResource GhostButton}" Padding="14,7"
                        Margin="0,0,10,0" Click="SignOut_Click" AutomationProperties.Name="Sign out" />
                <Button Content="Done" Style="{StaticResource PrimaryButton}" Padding="18,7"
                        Click="Done_Click" IsDefault="True" AutomationProperties.Name="Done" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
