<Window x:Class="VideoPlayer.App.Views.AccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account"
        Width="420" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource BodyFont}">
    <StackPanel Margin="24">
        <TextBlock x:Name="Heading" Text="Sign in" FontSize="19" FontWeight="Bold"
                   FontFamily="{StaticResource DisplayFont}"
                   Foreground="{StaticResource TextBrush}" />
        <TextBlock x:Name="Subhead" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="0,6,0,18" />

        <TextBlock x:Name="ErrorText" Text="" FontSize="12" TextWrapping="Wrap"
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12" Visibility="Collapsed" />

        <!-- Sign in / Register -->
        <StackPanel x:Name="FormPanel">
            <StackPanel x:Name="NameRow" Visibility="Collapsed">
                <TextBlock Text="DISPLAY NAME" FontSize="10.5" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                <Border Style="{StaticResource FieldBox}" Margin="0,0,0,14">
                    <TextBox x:Name="NameBox" Style="{StaticResource FieldText}" MaxLength="30"
                             AutomationProperties.Name="Display name" />
                </Border>
            </StackPanel>

            <TextBlock Text="EMAIL" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Style="{StaticResource FieldBox}" Margin="0,0,0,14">
                <TextBox x:Name="EmailBox" Style="{StaticResource FieldText}"
                         AutomationProperties.Name="Email" />
            </Border>

            <TextBlock Text="PASSWORD" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Style="{StaticResource FieldBox}">
                <PasswordBox x:Name="PassBox" Padding="10,9" FontSize="13.5"
                             Background="Transparent" Foreground="{StaticResource TextBrush}"
                             BorderThickness="0" AutomationProperties.Name="Password" />
            </Border>
            <TextBlock x:Name="PassHint" Text="At least 8 characters." FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}" Margin="2,6,0,0" Visibility="Collapsed" />

            <Button x:Name="ForgotLink" Content="Forgot password?" Style="{StaticResource LinkButton}"
                    HorizontalAlignment="Left" Margin="0,10,0,0" Click="Forgot_Click"
                    AutomationProperties.Name="Forgot password" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="ToggleBtn" Content="Create account" Style="{StaticResource GhostButton}"
                        Padding="12,7" Margin="0,0,10,0" Click="Toggle_Click"
                        AutomationProperties.Name="Switch mode" />
                <Button x:Name="SubmitBtn" Content="Sign in" Style="{StaticResource PrimaryButton}"
                        Padding="18,7" Click="Submit_Click" IsDefault="True"
                        AutomationProperties.Name="Submit" />
            </StackPanel>
        </StackPanel>

        <!-- Verify emailed code -->
        <StackPanel x:Name="VerifyPanel" Visibility="Collapsed">
            <TextBlock Text="VERIFICATION CODE" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Style="{StaticResource FieldBox}">
                <TextBox x:Name="CodeBox" Style="{StaticResource FieldText}" MaxLength="6"
                         FontSize="20" FontFamily="Consolas" AutomationProperties.Name="Verification code" />
            </Border>
            <Button x:Name="ResendLink" Content="Resend code" Style="{StaticResource LinkButton}"
                    HorizontalAlignment="Left" Margin="0,8,0,0" Click="Resend_Click"
                    AutomationProperties.Name="Resend code" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Back" Style="{StaticResource GhostButton}" Padding="12,7" Margin="0,0,10,0"
                        Click="Back_Click" AutomationProperties.Name="Back" />
                <Button x:Name="VerifyBtn" Content="Verify" Style="{StaticResource PrimaryButton}"
                        Padding="18,7" Click="Verify_Click" IsDefault="True" AutomationProperties.Name="Verify" />
            </StackPanel>
        </StackPanel>

        <!-- Forgot password: request a code -->
        <StackPanel x:Name="ForgotPanel" Visibility="Collapsed">
            <TextBlock Text="EMAIL" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Style="{StaticResource FieldBox}">
                <TextBox x:Name="ForgotEmailBox" Style="{StaticResource FieldText}"
                         AutomationProperties.Name="Email for reset" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Back" Style="{StaticResource GhostButton}" Padding="12,7" Margin="0,0,10,0"
                        Click="Back_Click" AutomationProperties.Name="Back" />
                <Button x:Name="SendCodeBtn" Content="Send code" Style="{StaticResource PrimaryButton}"
                        Padding="18,7" Click="SendCode_Click" IsDefault="True"
                        AutomationProperties.Name="Send code" />
            </StackPanel>
        </StackPanel>

        <!-- Reset: code + new password -->
        <StackPanel x:Name="ResetPanel" Visibility="Collapsed">
            <TextBlock Text="CODE" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Style="{StaticResource FieldBox}" Margin="0,0,0,14">
                <TextBox x:Name="ResetCodeBox" Style="{StaticResource FieldText}" MaxLength="6"
                         FontFamily="Consolas" AutomationProperties.Name="Reset code" />
            </Border>
            <TextBlock Text="NEW PASSWORD" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
            <Border Style="{StaticResource FieldBox}">
                <PasswordBox x:Name="ResetPassBox" Padding="10,9" FontSize="13.5"
                             Background="Transparent" Foreground="{StaticResource TextBrush}"
                             BorderThickness="0" AutomationProperties.Name="New password" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Back" Style="{StaticResource GhostButton}" Padding="12,7" Margin="0,0,10,0"
                        Click="Back_Click" AutomationProperties.Name="Back" />
                <Button x:Name="ResetBtn" Content="Reset password" Style="{StaticResource PrimaryButton}"
                        Padding="18,7" Click="Reset_Click" IsDefault="True"
                        AutomationProperties.Name="Reset password" />
            </StackPanel>
        </StackPanel>

        <!-- Signed in -->
        <StackPanel x:Name="SignedInPanel" Visibility="Collapsed">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16,12">
                <StackPanel>
                    <TextBlock x:Name="WhoName" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="WhoEmail" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0" />
                    <TextBlock x:Name="SyncStatus" FontSize="12" Foreground="{StaticResource AccentWarmBrush}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Button x:Name="FriendsBtn" Style="{StaticResource GhostButton}" Padding="14,9" Margin="0,12,0,0"
                    HorizontalAlignment="Stretch" Click="Friends_Click"
                    AutomationProperties.Name="Manage friends">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="FriendsBtnLabel" Text="Friends" FontSize="13" />
                </StackPanel>
            </Button>

            <Button x:Name="DeleteLink" Content="Delete account" Style="{StaticResource LinkButton}"
                    HorizontalAlignment="Left" Margin="2,14,0,0" Click="Delete_Click"
                    AutomationProperties.Name="Delete account" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Sign out" Style="{StaticResource GhostButton}" Padding="14,7"
                        Margin="0,0,10,0" Click="SignOut_Click" AutomationProperties.Name="Sign out" />
                <Button Content="Done" Style="{StaticResource PrimaryButton}" Padding="18,7"
                        Click="Done_Click" IsDefault="True" AutomationProperties.Name="Done" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
