<UserControl x:Class="VideoPlayer.App.Views.PasswordField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource FieldBox}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Masked and plain share the slot; the eye swaps which one shows. -->
            <PasswordBox x:Name="Masked" Grid.Column="0" Padding="10,9" FontSize="13.5"
                         Background="Transparent" Foreground="{StaticResource TextBrush}"
                         BorderThickness="0" VerticalContentAlignment="Center" />
            <TextBox x:Name="Plain" Grid.Column="0" Padding="10,9" FontSize="13.5"
                     Background="Transparent" Foreground="{StaticResource TextBrush}"
                     BorderThickness="0" VerticalContentAlignment="Center"
                     Visibility="Collapsed" />

            <Button x:Name="EyeBtn" Grid.Column="1" Click="Eye_Click" Cursor="Hand"
                    Background="Transparent" Padding="10,0" ToolTip="Show password"
                    AutomationProperties.Name="Show password">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock x:Name="EyeGlyph" Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                           FontSize="15" Foreground="{StaticResource TextMutedBrush}" />
            </Button>
        </Grid>
    </Border>
</UserControl>
