<UserControl x:Class="VideoPlayer.App.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             Background="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopBarRow" Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid x:Name="TopBar" Grid.Row="0" Background="{StaticResource BgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource GhostButton}" Click="BackBtn_Click"
                    AutomationProperties.Name="Back to library" Margin="12,10" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Library" />
                </StackPanel>
            </Button>
            <TextBlock x:Name="TitleText" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0"
                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                       TextTrimming="CharacterEllipsis" />
            <Button x:Name="AutoplayBtn" Grid.Column="2" Style="{StaticResource GhostButton}"
                    Click="AutoplayBtn_Click" AutomationProperties.Name="Autoplay"
                    Margin="0,10,8,10" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="AutoplayGlyph" Text="&#xE8EE;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Autoplay" />
                </StackPanel>
            </Button>
            <Button x:Name="CastBtn" Grid.Column="3" Style="{StaticResource GhostButton}" Click="CastBtn_Click"
                    AutomationProperties.Name="Cast to device" Margin="0,10,12,10" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="CastGlyph" Text="&#xEC15;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="CastLabel" Text="Cast" />
                </StackPanel>
            </Button>
        </Grid>

        <vlc:VideoView x:Name="Video" Grid.Row="1" Background="Black">
            <!-- Content renders in libVLC's transparent overlay window — the only
                 way WPF elements can sit above the video HWND. -->
            <Grid Background="Transparent" MouseLeftButtonDown="VideoArea_MouseDown">

                <!-- Host toasts (guest joined / pause requests) -->
                <StackPanel x:Name="ToastPanel" VerticalAlignment="Top" HorizontalAlignment="Center"
                            Margin="0,14,0,0" />

                <!-- Party chat -->
                <Border x:Name="ChatPanel" Visibility="Collapsed" HorizontalAlignment="Right"
                        VerticalAlignment="Stretch" Width="280" Margin="0,10,10,10"
                        Background="#D91A0D09" CornerRadius="12" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="PARTY CHAT" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="4,0,0,6" />
                        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ChatList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12.5"
                                                   Foreground="{StaticResource TextBrush}" Margin="4,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBox Grid.Row="2" x:Name="ChatInput" Margin="0,8,0,0" Padding="8,6" FontSize="12.5"
                                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource LineBrush}" KeyDown="ChatInput_KeyDown"
                                 AutomationProperties.Name="Chat message" />
                    </Grid>
                </Border>

                <Border x:Name="CastBanner" Visibility="Collapsed" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="14"
                        Padding="28,22">
                    <StackPanel>
                        <TextBlock Text="&#xEC15;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CastBannerText" Text="Casting" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,12,0,4" />
                        <TextBlock Text="The movie is playing on the device — controls below still work."
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </vlc:VideoView>

        <!-- Controls -->
        <Grid x:Name="ControlBar" Grid.Row="2" Background="{StaticResource SurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Seek row -->
            <Grid Grid.Row="0" Margin="14,8,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TimeText" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"
                           FontFamily="Consolas" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Text="0:00" />
                <Slider x:Name="Seek" Grid.Column="1" VerticalAlignment="Center" Maximum="1000" />
                <TextBlock x:Name="DurationText" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                           FontFamily="Consolas" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Text="0:00" />
                <Popup x:Name="ScrubPopup" PlacementTarget="{Binding ElementName=Seek}" Placement="Relative"
                       AllowsTransparency="True" IsHitTestVisible="False">
                    <Border Background="#E60E0604" CornerRadius="10" Padding="10,5">
                        <TextBlock x:Name="ScrubText" Foreground="White" FontFamily="Consolas" FontSize="12.5"
                                   FontWeight="Bold" />
                    </Border>
                </Popup>
            </Grid>

            <!-- Buttons row: transport centered, utilities right, codec info left -->
            <Grid Grid.Row="1" Margin="10,4,10,8">
                <TextBlock x:Name="InfoText" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PrevBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="PrevBtn_Click" AutomationProperties.Name="Previous">
                        <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="Back10_Click" AutomationProperties.Name="Back 10 seconds">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEB9E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,5,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="-10sec" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="PlayBtn" Style="{StaticResource PrimaryButton}" Padding="16,8" Margin="4,0"
                            Click="PlayBtn_Click" AutomationProperties.Name="Play or pause">
                        <TextBlock x:Name="PlayGlyph" Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="Fwd10_Click" AutomationProperties.Name="Forward 10 seconds">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+10sec" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="&#xEB9D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NextBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="NextBtn_Click" AutomationProperties.Name="Next">
                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ChatBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Visibility="Collapsed" Click="ChatBtn_Click" AutomationProperties.Name="Party chat">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button x:Name="ChaptersBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="ChaptersBtn_Click" AutomationProperties.Name="Chapters">
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button x:Name="AudioBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="AudioBtn_Click" AutomationProperties.Name="Audio track">
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button x:Name="SubsBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="SubsBtn_Click" AutomationProperties.Name="Subtitles">
                        <TextBlock x:Name="SubsGlyph" Text="CC" FontSize="12" FontWeight="Bold" />
                    </Button>
                    <Button x:Name="RateBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="RateBtn_Click" AutomationProperties.Name="Playback speed">
                        <TextBlock x:Name="RateText" Text="1×" FontSize="12" FontWeight="Bold" />
                    </Button>
                    <Button x:Name="MuteBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="MuteBtn_Click" AutomationProperties.Name="Mute">
                        <TextBlock x:Name="MuteGlyph" Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Slider x:Name="VolumeSlider" Width="90" Maximum="100" VerticalAlignment="Center" Margin="2,0,8,0"
                            AutomationProperties.Name="Volume" />
                    <Button x:Name="FullscreenBtn" Style="{StaticResource GhostButton}" Padding="10,8" Margin="2,0"
                            Click="FullscreenBtn_Click" AutomationProperties.Name="Fullscreen">
                        <TextBlock x:Name="FullscreenGlyph" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
