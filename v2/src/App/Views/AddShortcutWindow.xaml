<Window x:Class="VideoPlayer.App.Views.AddShortcutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add streaming shortcut"
        Width="480" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource BodyFont}">
    <StackPanel Margin="24">
        <TextBlock Text="Add streaming shortcut" FontSize="19" FontWeight="Bold"
                   FontFamily="{StaticResource DisplayFont}"
                   Foreground="{StaticResource TextBrush}" />
        <TextBlock Text="A card in your library that opens the service. These titles are DRM-protected, so they play in the service's own app — not here."
                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="0,6,0,18" />

        <TextBlock Text="TITLE" FontSize="10.5" FontWeight="Bold"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
            <TextBox x:Name="TitleBox" Padding="10,9" FontSize="13.5" MaxLength="120"
                     Background="Transparent" Foreground="{StaticResource TextBrush}"
                     BorderThickness="0" TextChanged="Validate"
                     AutomationProperties.Name="Shortcut title" />
        </Border>

        <TextBlock Text="SERVICE" FontSize="10.5" FontWeight="Bold"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,6" />
        <ComboBox x:Name="ServiceBox" HorizontalAlignment="Stretch"
                  AutomationProperties.Name="Streaming service" />

        <TextBlock Text="DIRECT LINK (OPTIONAL)" FontSize="10.5" FontWeight="Bold"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,6" />
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
            <TextBox x:Name="UrlBox" Padding="10,9" FontSize="12.5"
                     Background="Transparent" Foreground="{StaticResource TextBrush}"
                     BorderThickness="0" TextChanged="Validate"
                     AutomationProperties.Name="Direct link" />
        </Border>
        <TextBlock x:Name="UrlHint"
                   Text="Paste the title's page from the service for a one-click open. Leave blank to search the service by title instead."
                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="2,6,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}"
                    Click="Cancel_Click" IsCancel="True" Margin="0,0,10,0" />
            <Button x:Name="AddBtn" Content="Add to library" Style="{StaticResource PrimaryButton}"
                    Click="Add_Click" IsDefault="True" IsEnabled="False" />
        </StackPanel>
    </StackPanel>
</Window>
