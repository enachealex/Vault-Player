<Window x:Class="VideoPlayer.App.Views.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Friends"
        Width="440" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource BodyFont}">
    <StackPanel Margin="24">
        <TextBlock x:Name="Heading" Text="Friends" FontSize="19" FontWeight="Bold"
                   FontFamily="{StaticResource DisplayFont}"
                   Foreground="{StaticResource TextBrush}" />
        <TextBlock x:Name="Subhead" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="0,6,0,18"
                   Text="Add a friend by the email on their Vault Movies account, then invite them into a Watch Party." />

        <!-- Add a friend -->
        <TextBlock Text="ADD BY EMAIL" FontSize="10.5" FontWeight="Bold"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource FieldBox}">
                <TextBox x:Name="EmailBox" Style="{StaticResource FieldText}"
                         AutomationProperties.Name="Friend email" />
            </Border>
            <Button x:Name="AddBtn" Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="Add"
                    Padding="18,7" Margin="10,0,0,0" Click="Add_Click" IsDefault="True"
                    AutomationProperties.Name="Add friend" />
        </Grid>
        <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                   Foreground="{StaticResource AccentBrush}" Margin="2,8,0,0" Visibility="Collapsed" />

        <!-- Incoming requests -->
        <StackPanel x:Name="RequestsSection" Visibility="Collapsed" Margin="0,20,0,0">
            <TextBlock Text="REQUESTS" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
            <ItemsControl x:Name="RequestsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="14,10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding Email}" FontSize="11.5"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButton}" Content="Accept"
                                            FontSize="12" Padding="14,6" Tag="{Binding}" Click="Accept_Click"
                                            AutomationProperties.Name="{Binding Name, StringFormat='Accept {0}'}" />
                                    <Button Style="{StaticResource GhostButton}" Content="Decline"
                                            FontSize="12" Padding="12,6" Margin="6,0,0,0" Tag="{Binding}"
                                            Click="Decline_Click"
                                            AutomationProperties.Name="{Binding Name, StringFormat='Decline {0}'}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Friends -->
        <StackPanel Margin="0,20,0,0">
            <TextBlock Text="YOUR FRIENDS" FontSize="10.5" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
            <TextBlock x:Name="EmptyFriends" Visibility="Collapsed" FontSize="12.5"
                       Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"
                       Text="No friends yet. Add one by email above — they'll get a request to accept." />
            <ItemsControl x:Name="FriendsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="14,10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding Email}" FontSize="11.5"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,1,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Remove"
                                        FontSize="12" Padding="12,6" Tag="{Binding}" Click="Remove_Click"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="{Binding Name, StringFormat='Remove {0}'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Outgoing (pending) -->
        <StackPanel x:Name="PendingSection" Visibility="Collapsed" Margin="0,4,0,0">
            <TextBlock x:Name="PendingText" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Done" Style="{StaticResource PrimaryButton}" Padding="18,7"
                    Click="Done_Click" AutomationProperties.Name="Done" />
        </StackPanel>
    </StackPanel>
</Window>
