<Window x:Class="VideoPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Video Player"
        Width="1280" Height="800" MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource BodyFont}"
        StateChanged="Window_StateChanged">

    <!-- Custom chrome: keeps native drag / snap / resize behaviour but lets us
         draw the title bar ourselves. CaptionHeight must match the title bar
         row, or the draggable strip won't line up with what's on screen. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{StaticResource BgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar" Grid.Row="0" Height="38"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Brand mark + title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Border Width="16" Height="16" CornerRadius="5"
                                Background="{StaticResource AccentBrush}" />
                        <TextBlock x:Name="TitleText" Text="Video Player" FontSize="12.5"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>

                    <!-- Context line (e.g. the movie currently playing) -->
                    <TextBlock x:Name="TitleSubtext" Grid.Column="1" Text="" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="14,0"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="MinBtn" Style="{StaticResource CaptionButton}"
                                Click="MinBtn_Click" Content="&#xE921;"
                                ToolTip="Minimise" AutomationProperties.Name="Minimise" />
                        <Button x:Name="MaxBtn" Style="{StaticResource CaptionButton}"
                                Click="MaxBtn_Click" Content="&#xE922;"
                                ToolTip="Maximise" AutomationProperties.Name="Maximise" />
                        <Button x:Name="CloseBtn" Style="{StaticResource CaptionCloseButton}"
                                Click="CloseBtn_Click" Content="&#xE8BB;"
                                ToolTip="Close" AutomationProperties.Name="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl x:Name="Host" Grid.Row="1" />
        </Grid>
    </Border>
</Window>
